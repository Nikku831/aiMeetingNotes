# ==============================================================================
# AI Meeting Notes - Environment Variables
# Copy this file to `.env.local` and replace the placeholder values with your own.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. App URL
# Used by Stripe to know where to redirect the user after a successful checkout.
# Use http://localhost:3000 for local development.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 2. Supabase Settings
# Get these from: Supabase Dashboard -> Project Settings -> API
# ------------------------------------------------------------------------------
# The URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# The anonymous key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key...
# The service role key (NEVER expose this to the browser - used for webhooks)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...

# ------------------------------------------------------------------------------
# 3. Groq API (AI Model)
# Get this from: https://console.groq.com/keys
# ------------------------------------------------------------------------------
# Your Groq API key (Starts with gsk_)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ------------------------------------------------------------------------------
# 4. Stripe Settings
# Get these from: Stripe Dashboard -> Developers -> API Keys
# ------------------------------------------------------------------------------
# Your secret API key (starts with sk_test_ for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Your publishable key (starts with pk_test_ for development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# The Price ID of your Pro plan (starts with price_)
# Create a product in Stripe Dashboard -> Products, then copy the Price ID
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

# The Webhook Secret
# For local testing, run: stripe listen --forward-to localhost:3000/api/stripe/webhook
# The CLI will output a webhook secret starting with whsec_
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
